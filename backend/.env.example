# Database
DATABASE_URL=postgresql+asyncpg://invplatform:invplatform@localhost:5434/invplatform
DATABASE_URL_SYNC=postgresql+psycopg://invplatform:invplatform@localhost:5434/invplatform

# Redis / Celery
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/1

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# HuggingFace Hub — required for gated models (SAM 3.1, Parakeet are gated as of 2026).
# Get one at https://huggingface.co/settings/tokens (read-only is enough).
# Loaded automatically by `transformers` and `huggingface_hub` from the environment.
HF_TOKEN=

# Storage
DATA_DIR=../data
VIDEOS_DIR=../data/videos
FRAMES_DIR=../data/frames
THUMBNAILS_DIR=../data/thumbnails

# Frame sampling
DEFAULT_MIN_FRAMES_PER_SHOT=1
DEFAULT_MAX_INTER_FRAME_SECONDS=3.0

# ML mode — false on a GPU box with real models installed; true for dev.
USE_FAKE_ML=true

# Comma-separated absolute paths the API is allowed to scan for videos
# (used by POST /api/ingest/scan). Empty disables server-side scanning.
# Example: INGEST_SCAN_ROOTS=/home/omiros/footage,/data/cctv
INGEST_SCAN_ROOTS=